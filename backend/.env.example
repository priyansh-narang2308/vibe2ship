# General Settings
ENVIRONMENT=development
PORT=8000

# Google AI Studio / Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id_here
# Optional: Path to local firebase-credentials.json service account file
# If not provided, it will try to use Google Application Default Credentials (ADC)
FIREBASE_CREDENTIALS_PATH=

# Google Cloud Storage Bucket for storing images and PDFs
GCS_BUCKET_NAME=your_gcs_bucket_name_here

# Google Maps API Key (needs Geocoding API enabled)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# SendGrid (Email notifications)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_FROM_NUMBER=+1234567890
