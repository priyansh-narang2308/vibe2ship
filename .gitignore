# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this can be useful so that everyone uses the same version.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if platform is not identical, the lock file will
#   prevent installation of package.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in git.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in git.
#.pdm-python.path
#.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath vars
*.sage.py

